{
  "$schema": "./hardware_schema.json",
  "name": "Ascend 910B3",
  "vendor": "Huawei",
  "version": "3.0",
  "_v3_note": "Per-opcode cycle costs calibrated via CCE microbenchmarks (2026-06-25) on triton_profiling (CANN 8.5). Chunk E2E ratio improved from 0.12→0.63. Split E2E improved from 0.023→0.17.",

  "clock": {
    "frequency_ghz": 1.85,
    "cycles_per_us": 1850,
    "notes": "910B3 has higher clock than 910B4 (1.65 GHz). Confirmed via CCE kernel cycle counter or msprof metadata."
  },

  "memory_spaces": {
    "hbm": {
      "type": "off_chip",
      "size_gb": 32,
      "bandwidth_tbps": 1.6,
      "latency_cycles": 200
    },
    "l2": {
      "type": "on_chip_shared",
      "size_mb": 192,
      "bandwidth_gbps": 3200,
      "latency_cycles": 50
    },
    "l1": {
      "type": "on_chip_local",
      "size_kb": 1024,
      "bandwidth_gbps": 6400,
      "latency_cycles": 10,
      "description": "Cube data staging buffer"
    },
    "l0a": {
      "type": "register_file",
      "size_kb": 64,
      "description": "Left matrix input for Cube"
    },
    "l0b": {
      "type": "register_file",
      "size_kb": 64,
      "description": "Right matrix input for Cube"
    },
    "l0c": {
      "type": "register_file",
      "size_kb": 256,
      "description": "Cube output accumulator"
    },
    "ub": {
      "type": "on_chip_local",
      "size_kb": 256,
      "bandwidth_gbps": 3200,
      "latency_cycles": 5,
      "description": "Unified Buffer for Vector compute"
    }
  },

  "compute_units": {
    "cube": {
      "type": "matrix_engine",
      "tflops_fp16": 320,
      "tflops_fp32": 160,
      "tflops_int8": 640,
      "fractal_sizes": {
        "fp16": { "m": 16, "k": 16, "n": 16 },
        "bf16": { "m": 16, "k": 16, "n": 16 },
        "fp32": { "m": 16, "k": 8, "n": 16 },
        "int8": { "m": 16, "k": 32, "n": 16 }
      },
      "tile_m": 16,
      "tile_n": 16,
      "tile_k": 16,
      "input_spaces": ["l0a", "l0b"],
      "output_space": "l0c",
      "supported_dtypes": ["fp16", "bf16", "fp32", "int8"]
    },
    "vector": {
      "type": "simd_engine",
      "width_elements": 128,
      "width_bytes": 256,
      "tflops_fp32": 10,
      "tflops_fp16": 20,
      "compute_space": "ub",
      "supported_ops": [
        "add", "sub", "mul", "div", "max", "min",
        "exp", "log", "sqrt", "rsqrt", "tanh", "sigmoid", "relu",
        "reduce_sum", "reduce_max", "reduce_min",
        "cast", "broadcast", "cmp", "sel", "brc",
        "and", "or", "not", "arange", "copy"
      ],
      "supported_dtypes": ["fp32", "fp16", "bf16", "int32", "int8"]
    }
  },

  "data_movers": {
    "cube_mte2": {
      "description": "Cube input: HBM to L1",
      "src_space": "hbm",
      "dst_space": "l1",
      "bandwidth_gbps": 200,
      "max_burst_bytes": 65536,
      "alignment_bytes": 32
    },
    "mte1": {
      "description": "Cube input: L1 to L0A/L0B",
      "src_space": "l1",
      "dst_spaces": ["l0a", "l0b"],
      "bandwidth_gbps": 400,
      "max_burst_bytes": 32768,
      "alignment_bytes": 32
    },
    "fixpipe": {
      "description": "Cube output: L0C to HBM",
      "src_space": "l0c",
      "dst_space": "hbm",
      "bandwidth_gbps": 200,
      "max_burst_bytes": 65536,
      "alignment_bytes": 32,
      "supports_accumulate": true,
      "supports_cast": true
    },
    "vector_mte2": {
      "description": "Vector input: HBM to UB",
      "src_space": "hbm",
      "dst_space": "ub",
      "bandwidth_gbps": 200,
      "max_burst_bytes": 65536,
      "alignment_bytes": 32
    },
    "mte3": {
      "description": "Vector output: UB to HBM",
      "src_space": "ub",
      "dst_space": "hbm",
      "bandwidth_gbps": 200,
      "max_burst_bytes": 65536,
      "alignment_bytes": 32
    }
  },

  "pipeline": {
    "cube_path": {
      "stages": ["cube_mte2", "mte1", "cube", "fixpipe"],
      "description": "Matrix multiplication data flow",
      "fully_pipelined": true
    },
    "vector_path": {
      "stages": ["vector_mte2", "vector", "mte3"],
      "description": "Vector computation data flow",
      "fully_pipelined": true
    },
    "hardware_units": {
      "cube_mte2": { "path": "cube", "can_overlap": true },
      "mte1":      { "path": "cube", "can_overlap": true },
      "cube":      { "path": "cube", "can_overlap": true },
      "fixpipe":   { "path": "cube", "can_overlap": true },
      "vector_mte2": { "path": "vector", "can_overlap": true },
      "vector":      { "path": "vector", "can_overlap": true },
      "mte3":        { "path": "vector", "can_overlap": true }
    },
    "parallelism": {
      "inter_path": {
        "cube_path_and_vector_path": true,
        "description": "Cube and Vector paths execute in parallel"
      },
      "intra_path": {
        "cube_mte2_mte1_cube_fixpipe": true,
        "vector_mte2_vector_mte3": true,
        "description": "All units within each path can execute in parallel (pipelined)"
      }
    }
  },

  "performance_model": {
    "cube_cycles_per_tile": {
      "formula": "ceil(M/16) * ceil(N/16) * ceil(K/16)",
      "base_cycles": 1
    },
    "vector_cycles_per_op": {
      "formula": "ceil(elements / 128)",
      "base_cycles": 1
    },
    "memory_cycles": {
      "formula": "bytes / bandwidth_per_cycle",
      "include_latency": true
    }
  },

  "calibration": {
    "description": "v3 per-opcode calibration from CCE microbenchmarks on triton_profiling (CANN 8.5, Ascend 910B3). 2026-06-25.",
    "calib_file": "perfbound/calibration/data/calib_910b3_v3_opcode.json",
    "bandwidth_csv": "perfbound/calibration/data/bandwidth_910b3.csv",
    "vec_cycle_csv": "perfbound/calibration/data/vec_cycle_910b3_v3.csv",
    "notes": "Chunk_kda E2E ratio improved from 0.12→0.63 (5.2×). Split_qkv improved from 0.023→0.17 (7.5×). All values are measured sustained rates, not datasheet peaks.",

    "startup_latencies": {
      "vector_startup_cycles": 35,
      "mte2_startup_cycles": 50,
      "mte3_startup_cycles": 40,
      "cube_startup_cycles": 20,
      "fixpipe_startup_cycles": 30,
      "mte1_startup_cycles": 10,
      "notes": "MTE3=40 verified by chunk profiling (PIPE_MTE3 ratio=1.1). Others are datasheet seeds."
    },

    "vector_op_cycles_per_vec_instruction": {
      "simple_ops_add_sub_mul_etc": 3,
      "exp": 83,
      "log": 83,
      "tanh": 83,
      "sigmoid": 83,
      "sqrt": 83,
      "rsqrt": 83,
      "div": 5,
      "brc": 15,
      "cast": 10,
      "cmp": 6,
      "sel": 5,
      "reduce_sum": 10,
      "reduce_max": 10,
      "reduce_min": 10,
      "reduce_prod": 10,
      "bitwise_and": 3,
      "bitwise_or": 5,
      "bitwise_not": 4,
      "broadcast": 15,
      "arange": 10,
      "copy": 3,
      "_measured_raw": {
        "vmul": 3.0, "vadd": 3.5, "vsub": 3.4, "vmax": 3.0, "vmin": 3.0,
        "vdiv": 5.2, "vbrc": 14.6, "vcast": 10.2, "vcmp": 5.5,
        "vsel": 4.5, "vreduce": 10.1, "vand": 3.2, "vor": 5.4,
        "vnot": 4.0, "varange": 9.9, "vexp": 82.6, "vlog": 82.6,
        "vsqrt": 82.6, "vrsqrt": 82.6, "copy": 3.0
      }
    },

    "scalar_overhead": {
      "aiv_scalar_alu_width": 1,
      "aic_scalar_alu_width": 1,
      "max_scalar_ops_per_cycle_per_core": 1,
      "verified_by": "chunk_kda: AIC scalar ratio=0.035, AIV scalar ratio=0.258. Confirms 1-wide scalar ALU."
    },

    "parallelism": {
      "num_aic_cores": 20,
      "num_aiv_cores": 40,
      "block_launch_overhead_us": 0.12,
      "description": "Block overhead verified via chunk_kda: (111,892 - 111,384) / 4096 = 0.12 us/block."
    }
  }
}
